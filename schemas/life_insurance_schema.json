{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LifeInsuranceMarketData",
  "type": "object",
  "required": ["period", "companies"],
  "properties": {
    "period": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
    "companies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kpis"],
        "properties": {
          "id":   { "type": "string" },
          "name": { "type": "string" },
          "kpis": {
            "type": "object",
            "properties": {
              "gross_premium":  { "type": ["number", "null"] },
              "benefit_ratio":  { "type": ["number", "null"] }
            }
          }
        }
      }
    }
  }
}
